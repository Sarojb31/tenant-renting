# Database
DATABASE_URL=postgresql://roomfinder:roomfinder_dev@localhost:5432/roomfinder

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m

# SMS — Nepal (Sparrow SMS)
SMS_SPARROW_API_KEY=
SMS_SPARROW_API_URL=https://apisms.sparrowsms.com/v2/sms/

# SMS — International (Twilio)
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=

# Payments — Nepal
PAYMENT_ESEWA_MERCHANT_ID=
PAYMENT_ESEWA_SECRET=
PAYMENT_KHALTI_SECRET_KEY=

# Payments — International
PAYMENT_STRIPE_SECRET_KEY=
PAYMENT_STRIPE_WEBHOOK_SECRET=

# File Storage (AWS S3 / Cloudflare R2)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1
S3_ENDPOINT=

# App URLs
APP_BASE_URL=http://localhost:3000
CUSTOMER_APP_BASE_URL=http://localhost:5173

# Facebook Page Integration (Phase 3)
FB_PAGE_ACCESS_TOKEN=
FB_WEBHOOK_VERIFY_TOKEN=

# Runtime
NODE_ENV=development
PORT=3000
