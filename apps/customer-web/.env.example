# Required — backend base URL (no /api suffix; NestJS has no global prefix)
VITE_API_URL=http://localhost:3000

# Required in local dev — tenant UUID sent as x-tenant-id header
# (localhost has no subdomain; server resolves tenant from this header)
# Get UUID from tenants table after: cd apps/backend && npm run seed
VITE_TENANT_ID=00000000-0000-0000-0000-000000000010

# Production overrides:
# VITE_API_URL=https://api.yourdomain.com
# VITE_TENANT_ID=   (leave blank — server resolves from subdomain)
