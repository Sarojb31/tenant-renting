# Required in local dev — tenant UUID to send as x-tenant-id header
# (localhost has no subdomain, so server can't resolve tenant from host)
# Get this UUID from the tenants table after running: cd apps/backend && npm run seed
VITE_TENANT_ID=00000000-0000-0000-0000-000000000010

# In production with real subdomains, leave blank — server resolves tenant from subdomain
# VITE_TENANT_ID=

# Backend base URL — leave unset in local dev (Vite proxy handles /api/* → localhost:3000/*)
# In production, set to backend base URL without /api suffix
# VITE_API_URL=https://api.yourdomain.com
