NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://roomfinder:roomfinder_dev@localhost:5432/roomfinder

# Redis
REDIS_URL=redis://localhost:6379

# JWT — change these in production (min 32 chars each)
JWT_ACCESS_SECRET=your-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters

# SMS — leave blank to use NullSmsAdapter (safe for local dev)
SMS_SPARROW_API_KEY=
SMS_SPARROW_API_URL=https://api.sparrowsms.com/v2/sms/
SMS_SPARROW_FROM=RoomFinder
SMS_AAKASH_API_KEY=
SMS_AAKASH_API_URL=
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_FROM=

# Payments — leave blank to disable gateway
PAYMENT_STRIPE_SECRET_KEY=
PAYMENT_STRIPE_WEBHOOK_SECRET=
PAYMENT_ESEWA_MERCHANT_ID=EPAYTEST
PAYMENT_ESEWA_SECRET=
PAYMENT_KHALTI_SECRET_KEY=

# File storage — leave blank to use NullStorageAdapter
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1
S3_ENDPOINT=

# App URLs
APP_BASE_URL=http://localhost:3000
CUSTOMER_APP_BASE_URL=http://localhost:5173

# Facebook (Phase 3 — leave blank)
FB_PAGE_ACCESS_TOKEN=
FB_WEBHOOK_VERIFY_TOKEN=
