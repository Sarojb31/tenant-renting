NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://roomfinder:roomfinder_dev@localhost:5432/roomfinder

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters

# Encryption key for sensitive stored values (FB page tokens, app secrets)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex chars (32 bytes). Dev falls back to insecure key if blank.
ENCRYPTION_KEY=

# SMS — leave blank to use NullSmsAdapter (safe for local dev)
# Sparrow SMS (Nepal +977 numbers): https://sparrowsms.com
SMS_SPARROW_API_KEY=
SMS_SPARROW_API_URL=https://api.sparrowsms.com/v2/sms/
SMS_SPARROW_FROM=RoomFinder
# Aakash SMS (Nepal fallback)
SMS_AAKASH_API_KEY=
SMS_AAKASH_API_URL=
# Twilio (international)
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_FROM=

# Payments — leave blank to disable gateway (falls back gracefully)
# Stripe: https://dashboard.stripe.com/test/apikeys
PAYMENT_STRIPE_SECRET_KEY=
PAYMENT_STRIPE_WEBHOOK_SECRET=
# eSewa sandbox: https://rc-epay.esewa.com.np (test login: 9806800001 / Nepal@123)
PAYMENT_ESEWA_MERCHANT_ID=EPAYTEST
PAYMENT_ESEWA_SECRET=
# Khalti sandbox: https://a.khalti.com (test wallet: 9800000000 / Test@12345)
PAYMENT_KHALTI_SECRET_KEY=

# File storage — leave blank to use NullStorageAdapter (uploads succeed, URLs are empty)
# Cloudflare R2 recommended: https://dash.cloudflare.com → R2
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_ENDPOINT=

# App URLs
APP_BASE_URL=http://localhost:3000
CUSTOMER_APP_BASE_URL=http://localhost:5173
ADMIN_APP_BASE_URL=http://localhost:5174

# Facebook integration
# 1. Create app at https://developers.facebook.com → Business type
# 2. Settings → Basic: copy App ID and App Secret
# 3. Add Facebook Login product → Valid OAuth Redirect URI: http://localhost:3000/facebook/callback
# 4. Add Webhooks product → subscribe to 'messages' on your Page
FB_APP_ID=
FB_APP_SECRET=
FB_WEBHOOK_VERIFY_TOKEN=any-random-string-you-choose
