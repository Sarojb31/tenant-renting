{
  "name": "@roomfinder/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "dotenv -e .env -- jest --config ./jest.integration.config.ts --runInBand",
    "migration:run": "dotenv -e .env -- typeorm migration:run -d dist/src/config/typeorm.config.js",
    "migration:revert": "dotenv -e .env -- typeorm migration:revert -d dist/src/config/typeorm.config.js",
    "migration:generate": "dotenv -e .env -- typeorm migration:generate -d dist/src/config/typeorm.config.js",
    "migration:fresh": "dotenv -e .env -- typeorm schema:drop -d dist/src/config/typeorm.config.js && dotenv -e .env -- typeorm migration:run -d dist/src/config/typeorm.config.js",
    "seed": "dotenv -e .env -- ts-node --project tsconfig.json src/database/seeds/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.550.0",
    "@aws-sdk/s3-request-presigner": "^3.550.0",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/typeorm": "^10.0.2",
    "argon2": "^0.40.1",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ioredis": "^5.3.2",
    "joi": "^17.12.3",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.3.1",
    "twilio": "^6.0.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/twilio": "^3.19.3",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.4"
  }
}
